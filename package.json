{
  "name": "sona",
  "version": "1.0.0",
  "description": "SONA — High Density Sonic Proto",
  "author": {
    "name": "SONA",
    "email": "sona@sona.app"
  },
  "homepage": "https://hac8k26.github.io/sona",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux"
  },
  "build": {
    "appId": "com.sona.app",
    "productName": "SONA",
    "files": [
      "electron/**/*",
      "*.html",
      "*.js",
      "assets/**/*"
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Audio",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
